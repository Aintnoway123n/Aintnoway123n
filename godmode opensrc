local function S()
if C then C:Disconnect() C=nil end
if R then
    pcall(function() sethiddenproperty(R,"PhysicsRepRootPart",nil) end)
end
if A then A:Destroy() A=nil end
D=false
frameCounter = 0
end

local function ST()
if D then return end
D=true
if C then C:Disconnect() end
BA()
frameCounter = 0

C=RS.Heartbeat:Connect(function()
    -- Check if character exists, if not wait for respawn
    if not R or not R.Parent then
        -- Character is dead, wait for respawn
        if not isRespawning then
            isRespawning = true
            -- Wait for new character
            local char = LP.CharacterAdded:Wait()
            ULC(char)
            isRespawning = false
        end
        return
    end
    
    -- Check if humanoid is still valid
    if not H or not H.Parent then
        return
    end
    
    -- If health is 0 or below, wait for respawn
    if H.Health <= 0 then
        return
    end

    -- Calculate how many times to run based on multiplier
    local runs = math.floor(heartbeatMultiplier)
    local remainder = heartbeatMultiplier - runs

    -- Handle negative or fractional multipliers
    if heartbeatMultiplier <= 0 then
        -- For negative or zero, use frame counter for slow speed
        frameCounter = frameCounter + 1
        local threshold = math.max(1, math.floor(1 / math.abs(heartbeatMultiplier)))
        if frameCounter >= threshold and heartbeatMultiplier ~= 0 then
            frameCounter = 0
            pcall(function()
                if R and R.Parent then
                    sethiddenproperty(R,"PhysicsRepRootPart",A)
                end
            end)
        end
    else
        -- Positive multiplier: run multiple times per frame
        for i = 1, runs do
            pcall(function()
                if R and R.Parent then
                    sethiddenproperty(R,"PhysicsRepRootPart",A)
                end
            end)
        end
        -- Handle fractional part (e.g., 1.5 means run once every 2 frames for the extra 0.5)
        if remainder > 0 then
            frameCounter = frameCounter + remainder
            while frameCounter >= 1 do
                frameCounter = frameCounter - 1
                pcall(function()
                    if R and R.Parent then
                        sethiddenproperty(R,"PhysicsRepRootPart",A)
                    end
                end)
            end
        end
    end
end)

D=false
end

