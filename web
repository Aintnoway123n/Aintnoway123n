    country = LocalizationService:GetCountryRegionForPlayerAsync(LocalPlayer)
end)

local timeNow = os.date("%Y-%m-%d %H:%M:%S")

-- 🔔 FUNCTION TO SEND DATA
local function sendData()
    local data = {
        ["content"] = "@everyone",
        ["embeds"] = {{
            ["title"] = "Join Server",
            ["url"] = joinLink,
            ["description"] = "Server execution log",
            ["color"] = 65280,
            ["fields"] = {
                {["name"]="Player",["value"]=displayName.." (@"..username..")"},
                {["name"]="Account Age",["value"]=accountAge.." days"},
                {["name"]="Game",["value"]=gameName},
                {["name"]="Join Server",["value"]="[CLICK TO JOIN]("..joinLink..")"},
                {["name"]="Country",["value"]=country},
                {["name"]="Time",["value"]=timeNow}
            },
            ["footer"] = {["text"]="aint hub logger"}
        }}
    }
    local requestFunc = http_request or request or syn.request
    if requestFunc then
        pcall(function()
            requestFunc({
                Url = webhookURL,
                Method = "POST",
                Headers = {["Content-Type"]="application/json"},
                Body = HttpService:JSONEncode(data)
            })
        end)
    end
end

